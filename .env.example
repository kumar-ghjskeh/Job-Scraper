# ── Database ──────────────────────────────────────────────────────────────────
# Default: SQLite in data/jobs.db — no change needed for local use
DATABASE_URL=sqlite:///data/jobs.db

# ── API server ─────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Optional: Notion sync ─────────────────────────────────────────────────────
# Get your integration token from https://www.notion.so/my-integrations
NOTION_API_KEY=
NOTION_DATABASE_ID=

# ── Optional: Discord alerts ──────────────────────────────────────────────────
DISCORD_WEBHOOK_URL=

# ── Optional: Telegram alerts ─────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Optional: Email alerts ────────────────────────────────────────────────────
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ── Scraper behavior ──────────────────────────────────────────────────────────
PLAYWRIGHT_HEADLESS=true
REQUEST_TIMEOUT_SECONDS=30

# On cloud deploys with a fresh/empty database, run one scrape on startup so the
# dashboard is populated immediately instead of waiting for the first schedule.
RUN_SCRAPE_ON_STARTUP=false

# ── Production (Render) ────────────────────────────────────────────────────────
# Render injects DATABASE_URL automatically (postgres://...). Set CORS_ORIGINS to
# your Vercel URL, e.g. CORS_ORIGINS=https://job-scraper.vercel.app
